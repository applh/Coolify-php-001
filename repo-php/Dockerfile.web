FROM nginx:alpine

# Install vim for file editing, and unzip for archive restoration
RUN apk add --no-cache vim unzip

# Copy the nginx configuration into the image
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Set working directory & copy context
WORKDIR /var/www/html
COPY . .

# Hook for restoring codebases via binary compactions
RUN if [ -f archive.zip ]; then \
      echo "📦 [PHP Nginx Web] Found archive.zip! Extracting to restore precise file index..."; \
      unzip -o archive.zip && rm archive.zip; \
    else \
      echo "ℹ️ [PHP Nginx Web] No archive.zip found. Proceeding with standard git synchronized files."; \
    fi

EXPOSE 80
