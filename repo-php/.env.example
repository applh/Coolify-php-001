# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Coolify / Production Variables
APP_NAME="PHP_Coolify_Starter"
APP_ENV="production"
PORT=80

# Set to "true" to force reset of my-data volume from content/ on deployment
APP_DATA_RESET="false"

# Example of a secret set in Coolify Environment Variables
COOLIFY_APP_SECRET="super-secret-key-from-coolify"

# CMS Multi-site Debugging: Force a specific site directory from content/
# Useful when developing locally without direct domain mapping
ACTIVE_SITE_OVERRIDE="site2.com"

# Admin area protection
APP_ADMIN_PASSKEY="my_secure_passkey"

DATABASE_URL=""
MARIADB_ROOT_PASSWORD=""
